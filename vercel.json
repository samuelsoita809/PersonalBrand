{
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "devCommand": "npm run dev",
    "framework": "vite",
    "ignoreCommands": [
        "git diff --quiet HEAD^ HEAD ."
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}